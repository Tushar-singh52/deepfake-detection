{
  "class_names": [
    "FAKE",
    "REAL"
  ],
  "image_size": [
    224,
    224
  ],
  "model": "EfficientNetB0",
  "weights": "imagenet",
  "positive_class_index": 1,
  "args": {
    "data_dir": "data\\CIFAKE",
    "output_dir": "outputs",
    "batch_size": 16,
    "initial_epochs": 8,
    "fine_tune_epochs": 12,
    "learning_rate": 0.001,
    "fine_tune_learning_rate": 1e-05,
    "validation_split": 0.15,
    "label_smoothing": 0.05,
    "dropout": 0.35,
    "seed": 42,
    "cache_dataset": false
  }
}